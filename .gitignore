# Python bytecode + caches
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Virtual envs
venv/
.venv/
env/

# Customer data (NEVER commit — this folder is per-install data)
customer_install/data/
customer_install/data.preroll-*/
customer_install/snapshots/
customer_install/backups/
customer_install/bin/
customer_install/llm_local/
customer_install/tunnel/
customer_install/desktop_shortcuts/

# Local config + secrets
.env
*.env
config.json
*.local.json

# OS junk
.DS_Store
Thumbs.db

# Editor junk
.vscode/
.idea/
*.swp
*.swo
*~

# Test scratch
/tmp/

# Big installer-packaged outputs (regenerated by build; don't commit)
cross_platform/dist/
cross_platform/build/
*.zip
*.tar.gz
*.dmg
*.exe
*.pkg
usb_bundle/dist/

# Installer build artifacts (rebuild with build_orbi_installer.py)
customer_install/installer/dist/
customer_install/installer/build/
customer_install/installer/_bin_cache/
customer_install/installer/_bundled_runtime/

# Runtime models + logs + ephemeral queues (regenerated/per-install)
customer_install/tts_models/
customer_install/notify_queue.jsonl
customer_install/watchdog.log
customer_install/*.log
