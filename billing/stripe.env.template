# Copy this file to /etc/orbi-brain/stripe.env on the brain machine
# and fill in the real values. Then:
#   sudo chmod 600 /etc/orbi-brain/stripe.env
#   sudo chown orbi-brain:orbi-brain /etc/orbi-brain/stripe.env

# Stripe API key — find in Stripe Dashboard > Developers > API keys
# Use sk_test_... while developing, sk_live_... when ready for real payments
STRIPE_API_KEY=sk_test_REPLACE_ME

# Webhook signing secret — find when you create the webhook endpoint
# in Stripe Dashboard > Developers > Webhooks > [your endpoint] > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Admin token for Frank's manual override endpoints.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ORBI_ADMIN_TOKEN=REPLACE_WITH_LONG_RANDOM_STRING

# ---------------------------------------------------------------------------
# Stripe Price IDs — four tiers x two billing cycles = eight prices
# Create eight recurring products in Stripe Dashboard > Products, then paste
# each price_... ID here. No setup-fee product needed (dropped 2026-05-27).
# ---------------------------------------------------------------------------
STRIPE_PRICE_SMALL_MO=price_REPLACE_ME_small_99_monthly
STRIPE_PRICE_SMALL_YR=price_REPLACE_ME_small_999_annual
STRIPE_PRICE_MEDIUM_MO=price_REPLACE_ME_medium_149_monthly
STRIPE_PRICE_MEDIUM_YR=price_REPLACE_ME_medium_1499_annual
STRIPE_PRICE_LARGE_MO=price_REPLACE_ME_large_249_monthly
STRIPE_PRICE_LARGE_YR=price_REPLACE_ME_large_2499_annual
STRIPE_PRICE_ENT_MO=price_REPLACE_ME_ent_399_monthly
STRIPE_PRICE_ENT_YR=price_REPLACE_ME_ent_3999_annual

# How many days of grace after a failed payment before service stops.
ORBI_GRACE_DAYS=3

# SQLite database path.
ORBI_BILLING_DB=/opt/orbi-brain/billing.db

# Port the webhook server listens on (cloudflared tunnel exposes this).
PORT=5060

# ---------------------------------------------------------------------------
# Email delivery for install tokens — SMTP first, Resend optional
# ---------------------------------------------------------------------------
# The webhook tries these in order: SMTP → Resend → log-only fallback.
#
# RECOMMENDED (free): use your existing Yahoo / iCloud / Gmail account via
# SMTP. Generate an "app password" at:
#   - Yahoo:  https://login.yahoo.com/account/security → App passwords
#   - iCloud: https://appleid.apple.com → App-Specific Passwords
#   - Gmail:  https://myaccount.google.com → 2FA → App passwords
# Then fill these in:
ORBI_SMTP_HOST=smtp.mail.yahoo.com
ORBI_SMTP_PORT=587
ORBI_SMTP_USER=franklstreet@yahoo.com
ORBI_SMTP_PASSWORD=PASTE_16_CHAR_APP_PASSWORD_HERE
ORBI_FROM_EMAIL=Orby <franklstreet@yahoo.com>

# OPTIONAL UPGRADE: Resend for higher deliverability + better analytics.
# Free tier: 3,000 emails/month. Sign up at resend.com.
# If unset and SMTP also unset, install tokens get logged to journald.
RESEND_API_KEY=

# Where the downloadable installer lives. Linked from the install email.
ORBI_DOWNLOAD_BASE_URL=https://downloads.orbi.frank.com

# Where install records persist (single-file JSON, atomic writes).
ORBI_INSTALLS_PATH=/opt/orbi-brain/installs.json

# ---------------------------------------------------------------------------
# Brain proxy
# ---------------------------------------------------------------------------
# HuggingFace token used by /v1/chat/completions to call HF Inference on
# behalf of every paying customer. Get one at huggingface.co/settings/tokens
# (needs "Read" + "Make calls to Inference Providers" scopes).
HF_TOKEN=hf_REPLACE_ME

# Override if you ever move off HF Inference — must be an OpenAI-compatible
# host. Default works for HF Inference.
HF_API_BASE=https://api-inference.huggingface.co/models

# How long (seconds) to wait for HF before returning 502 to the customer.
# 70B cold-start can take ~30s; 60s gives margin.
BRAIN_TIMEOUT_S=60
